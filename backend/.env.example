# Database (MySQL)
DATABASE_URL="mysql://user:password@localhost:3306/crm_db"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV=development

# Optional: rate limit (global per IP; per-user applied on protected routes)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
RATE_LIMIT_PER_USER_MAX=100

# Redis (recommended for cache and BullMQ background jobs / automations)
# REDIS_URL=redis://localhost:6379

# Local uploads (used when S3 is not configured)
# UPLOAD_DIR=./uploads
# UPLOAD_URL_PREFIX=/uploads

# S3-compatible storage (AWS S3, MinIO, DigitalOcean Spaces). If set, file uploads use S3 instead of local disk.
# S3_BUCKET=my-bucket
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT=          # optional, e.g. http://localhost:9000 for MinIO
# S3_PUBLIC_URL=        # optional, e.g. https://my-bucket.s3.region.amazonaws.com (for public read URLs)

# WhatsApp (one provider; set WHATSAPP_PROVIDER = meta | twilio | dialog)
# WHATSAPP_PROVIDER=meta
# WHATSAPP_TENANT_ID=   # tenant id for webhook inbound (single-tenant webhook)
# Meta Cloud API
# WHATSAPP_META_PHONE_ID=
# WHATSAPP_META_ACCESS_TOKEN=
# WHATSAPP_META_APP_SECRET=  # for webhook signature verification
# WHATSAPP_META_VERIFY_TOKEN=  # for Meta webhook GET verification
# Twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# 360Dialog
# DIALOG_API_KEY=
# DIALOG_CHANNEL_ID=
# DIALOG_WEBHOOK_SECRET=

# Lead capture / Forms (optional)
# PUBLIC_API_URL=https://api.yourcrm.com
# RECAPTCHA_SITE_KEY=   # for embed form (v2 checkbox)
# RECAPTCHA_SECRET_KEY= # for server-side verify
